# Azure OpenAI configuration
# Copy to .env and fill in your values, or set these as environment variables.

# Required: Azure OpenAI resource endpoint
AZURE_OPENAI_ENDPOINT=https://YOUR-RESOURCE-NAME.openai.azure.com

# Required: Deployment name (must match exactly what's in Azure)
AZURE_OPENAI_DEPLOYMENT=gpt-5-mini

# Auth (choose one):
# Option A: API key
# AZURE_OPENAI_API_KEY=your-api-key-here
# Option B: Azure AD auth — just run 'az login' (no env var needed)
